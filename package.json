{
  "name": "z1mak-cv-queue",
  "version": "0.1.0",
  "description": "AI jobs API + worker service",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/server.js",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:cron": "node dist/cron.js",
    "start:worker:mock": "node -r ./dist/src/mock/registerGeminiMock.js dist/src/worker.js",
    "docker:up": "docker compose up --build",
    "lint": "ESLINT_USE_FLAT_CONFIG=0 eslint \"{src,api,types}/**/*.ts\"",
    "format": "prettier --check \"**/*.{ts,js,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,js,json,md}\"",
    "fix": "npm run lint -- --fix && npm run format:write",
    "test:unit": "vitest run test/unit",
    "test:integration": "TEST_USE_COMPOSE=1 vitest run test/integration --pool=forks --maxConcurrency=1",
    "test": "npm run test:unit && npm run test:integration",
    "build": "tsc -p tsconfig.json && npm run build:copy-lua",
    "build:copy-lua": "mkdir -p dist/src/redis && cp -r src/redis/luaScripts dist/src/redis/"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.5.0",
    "@supabase/supabase-js": "^2.48.0",
    "bullmq": "^5.12.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "immer": "^10.1.1",
    "ioredis": "^5.4.2",
    "luxon": "^3.7.2",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@eslint/eslintrc": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
