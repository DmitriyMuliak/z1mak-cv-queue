{
  "name": "z1mak-cv-queue",
  "version": "0.1.0",
  "description": "AI jobs API + worker service",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "docker compose -f docker-compose.develop.yml up",
    "start:build": "docker compose -f docker-compose.develop.yml up --build",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/src/worker/index.js",
    "start:cron": "node dist/src/cron/index.js",
    "start:worker:mock": "node -r ./dist/test/mock/MockGeminiProvider/registerGeminiMock.js dist/src/worker/index.js",
    "docker:up": "docker compose up --build",
    "lint": "ESLINT_USE_FLAT_CONFIG=0 eslint \"{src,api,types}/**/*.ts\"",
    "format": "prettier --check \"**/*.{ts,js,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,js,json,md}\"",
    "fix": "npm run lint -- --fix && npm run format:write",
    "test:unit": "vitest run test/unit",
    "test:integration": "TEST_USE_COMPOSE=1 vitest run test/integration --pool=forks --maxConcurrency=1",
    "test": "npm run test:unit && npm run test:integration",
    "build": "tsc -p tsconfig.build.json && npm run build:copy-lua",
    "build:copy-lua": "shx mkdir -p dist/src/redis && cp -r src/redis/luaScripts dist/src/redis/",
    "supabase": "supabase",
    "update-db-types": "supabase gen types typescript --local > ./src/types/supabase.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.5.0",
    "@sinclair/typebox": "^0.34.41",
    "@supabase/supabase-js": "^2.48.0",
    "bullmq": "^5.12.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "immer": "^10.1.1",
    "ioredis": "^5.4.2",
    "luxon": "^3.7.2",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "shx": "^0.4.0",
    "supabase": "^2.67.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.16"
  }
}
