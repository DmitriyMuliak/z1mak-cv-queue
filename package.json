{
  "name": "z1mak-cv-queue",
  "version": "0.2.1",
  "description": "AI jobs API + worker service",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DmitriyMuliak/z1mak-cv-queue.git"
  },
  "main": "dist/src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "docker compose --env-file .env.development -f docker-compose.develop.yml up",
    "start:build": "docker compose --env-file .env.development -f docker-compose.develop.yml up --build",
    "start:api": "node dist/src/server/index.js",
    "start:worker": "node dist/src/worker/index.js",
    "start:worker:mock": "node -r ./dist/test/mock/MockGeminiProvider/registerGeminiMock.js dist/src/worker/index.js",
    "dev:api": "dotenv -e .env.development -- tsx watch src/server/index.ts",
    "dev:worker": "dotenv -e .env.development -- tsx watch src/worker/index.ts",
    "dev:worker:mock": "dotenv -e .env.development -- tsx watch src/worker/dev-entrypoint.ts",
    "dev:mock-gemini": "dotenv -e .env.development -- tsx watch test/mock/MockGeminiProvider/geminiServer.ts",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=0 eslint \"{src,scripts,test}/**/*.ts\"",
    "format": "prettier --check \"**/*.{ts,js,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,js,json,md}\"",
    "fix": "npm run lint -- --fix && npm run format:write",
    "tsc": "tsc",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run -c vitest.integration.config.ts test/integration",
    "test:db:migrate": "tsx test/database/applyMigrations.ts",
    "test": "npm run test:unit && npm run test:integration",
    "build": "tsc -p tsconfig.build.json && npm run build:copy-lua",
    "build:copy-lua": "shx mkdir -p dist/src/redis && cp -r src/redis/luaScripts dist/src/redis/",
    "supabase": "supabase",
    "supabase:link": "supabase link --project-ref",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:pull": "supabase db pull",
    "supabase:types:update": "supabase gen types typescript --linked > src/types/database/sup-database-gen.ts",
    "kysely:types:update": "dotenv -e .env.development -- kysely-codegen --out-file src/types/database/database-gen.d.ts",
    "admin:make": "dotenv -e .env.development -- ts-node scripts/makeAdminExisting.ts",
    "admin:create": "dotenv -e .env.development -- ts-node scripts/createAdminUser.ts"
  },
  "keywords": [],
  "author": "Muliak Dmytro",
  "license": "MIT",
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@google/genai": "^1.38.0",
    "@sinclair/typebox": "^0.34.46",
    "@supabase/supabase-js": "^2.91.0",
    "bullmq": "^5.66.7",
    "fastify": "^5.7.1",
    "fastify-plugin": "^5.1.0",
    "get-jwks": "^11.0.3",
    "immer": "^11.1.3",
    "ioredis": "^5.9.2",
    "kysely": "^0.28.10",
    "luxon": "^3.7.2",
    "pg": "^8.17.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.2",
    "kysely-codegen": "^0.19.0",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "supabase": "^2.72.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "supabase": {
      "tar": "^7.5.6"
    },
    "elliptic": "^6.6.1"
  }
}
